// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  "agent_servers": {
    "claude-acp": {
      "default_config_options": {
        "model": "default"
      },
      "type": "registry",
    },
  },
  "project_panel": {
    "dock": "left",
  },
  "outline_panel": {
    "dock": "left",
  },
  "collaboration_panel": {
    "dock": "left",
  },
  "git_panel": {
    "dock": "left",
  },
  "cli_default_open_behavior": "new_window",
  "colorize_brackets": true,
  "wsl_connections": [
    {
      "distro_name": "Ubuntu-24.04",
      "user": null,
      "projects": [
        {
          "paths": ["/home/dawen"],
        },
      ],
    },
  ],
  "buffer_font_weight": 550.0,
  "edit_predictions": {
    "mode": "subtle",
  },
  "agent": {
    "dock": "right",
    "sidebar_side": "right",
    "single_file_review": true,
    "model_parameters": [],
  },
  // Language specific settings
  "languages": {
    "C++": {
      "format_on_save": "on",
      "hard_tabs": true,
      "tab_size": 4,
    },
    "Python": {
      "language_servers": ["ty", "ruff"],
      "format_on_save": "on",
    },
  },
  "inlay_hints": {
    "enabled": true,
  },
  "buffer_font_family": "CodeNewRoman Nerd Font Mono",
  "ui_font_family": "UbuntuSans Nerd Font Propo",
  "ui_font_size": 16,
  "buffer_font_size": 13.0,
  "base_keymap": "JetBrains",
  "icon_theme": {
    "mode": "dark",
    "light": "Zed (Default)",
    "dark": "Catppuccin Frappé",
  },
  "vim_mode": true,
  "scrollbar": { "show": "auto" },
  "telemetry": {
    "diagnostics": false,
    "metrics": false,
  },
  "theme": {
    "mode": "dark",
    "light": "Ayu Light",
    "dark": "Ultimate Dark Neo",
  },
  "terminal": {
    "shell": {
      "program": "nu",
    },
  },
}
